<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Smeal" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#FF6B6B</item>
        <item name="colorPrimaryVariant">#FF6B6B</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#2D3436</item>
        <item name="colorSecondaryVariant">#2D3436</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">#F8F9FA</item>
        <item name="android:windowLightStatusBar">true</item>
        <!-- Couleurs pour les champs de saisie (TextInputLayout) -->
        <item name="colorOnSurface">#636E72</item>

        <!-- TYPOGRAPHIE PAR DÉFAUT -->
        <item name="fontFamily">@font/poppins</item>
        <item name="android:fontFamily">@font/poppins</item>
    </style>

    <!-- Styles de texte réutilisables -->
    <style name="TextAppearance.Smeal.Headline" parent="TextAppearance.MaterialComponents.Headline5">
        <item name="fontFamily">@font/poppins</item>
        <item name="android:fontFamily">@font/poppins</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.Smeal.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="fontFamily">@font/poppins</item>
        <item name="android:fontFamily">@font/poppins</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.Smeal.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="fontFamily">@font/poppins</item>
        <item name="android:fontFamily">@font/poppins</item>
        <item name="android:textColor">#B2BEC3</item>
    </style>

    <!-- Style spécifique pour forcer la visibilité des OutlinedBox -->
    <style name="Widget.Smeal.TextInputLayout.OutlinedBox" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/input_stroke_color</item>
        <item name="hintTextColor">@color/liquid_primary</item>
        <item name="android:textColorHint">#B2BEC3</item>
        <item name="passwordToggleTint">@color/text_secondary</item>
        <!-- Optionnel: Augmenter un peu l'épaisseur quand c'est focalisé pour que ce soit plus visible -->
        <item name="boxStrokeWidthFocused">2dp</item>
    </style>

    <style name="CircleImage" parent="">
        <item name="cornerSize">50%</item>
    </style>
</resources>