<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/authFragment">

    <fragment
        android:id="@+id/authFragment"
        android:name="fr.smeal.ui.auth.AuthFragment"
        android:label="Connexion"
        tools:layout="@layout/fragment_auth">
        <action
            android:id="@+id/action_authFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/authFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_authFragment_to_registerFragment"
            app:destination="@id/registerFragment" />
    </fragment>

    <fragment
        android:id="@+id/registerFragment"
        android:name="fr.smeal.ui.auth.RegisterFragment"
        android:label="Inscription"
        tools:layout="@layout/fragment_register">
        <action
            android:id="@+id/action_registerFragment_to_homeFragment"
            app:destination="@id/homeFragment"
            app:popUpTo="@id/authFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/homeFragment"
        android:name="fr.smeal.ui.home.HomeFragment"
        android:label="Smeal"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/mapFragment"
        android:name="fr.smeal.ui.map.MapFragment"
        android:label="Carte"
        tools:layout="@layout/fragment_map" />

    <fragment
        android:id="@+id/accountFragment"
        android:name="fr.smeal.ui.account.AccountFragment"
        android:label="Mon Compte"
        tools:layout="@layout/fragment_account" />

    <fragment
        android:id="@+id/detailsFragment"
        android:name="fr.smeal.ui.details.DetailsFragment"
        android:label="Détails"
        tools:layout="@layout/fragment_details">
        <argument
            android:name="restaurantId"
            app:argType="string" />
        <action
            android:id="@+id/action_detailsFragment_to_cameraFragment"
            app:destination="@id/cameraFragment" />
    </fragment>

    <fragment
        android:id="@+id/cameraFragment"
        android:name="fr.smeal.ui.camera.CameraFragment"
        android:label="Prendre une photo"
        tools:layout="@layout/fragment_camera">
        <action
            android:id="@+id/action_cameraFragment_to_imageEditFragment"
            app:destination="@id/imageEditFragment" />
    </fragment>

    <fragment
        android:id="@+id/imageEditFragment"
        android:name="fr.smeal.ui.camera.ImageEditFragment"
        android:label="Retoucher la photo"
        tools:layout="@layout/fragment_image_edit">
        <argument
            android:name="imageUri"
            app:argType="string" />
    </fragment>

</navigation>