<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- State Selected (Active Filter) - Identical to "Réserver" button -->
    <item android:state_checked="true">
        <shape>
            <solid android:color="#FF6B6B" /> <!-- Solid Corail (Liquid Primary) -->
            <corners android:radius="16dp" />
            <stroke android:width="1.5dp" android:color="#FFFFFF" />
        </shape>
    </item>
    <!-- Default Glass State - More transparent for better Glass effect -->
    <item>
        <shape>
            <solid android:color="#4DFFFFFF" /> <!-- Semi-transparent white (Glass) -->
            <corners android:radius="16dp" />
            <stroke android:width="1.5dp" android:color="#80FFFFFF" /> <!-- Subtle white border -->
        </shape>
    </item>
</selector>