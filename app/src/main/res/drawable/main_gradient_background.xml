<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Fond de base -->
    <item>
        <shape>
            <gradient
                android:startColor="#FFF5F5"
                android:endColor="#FFE0E0"
                android:angle="135" />
        </shape>
    </item>

    <!-- Bulle de couleur en haut à gauche -->
    <item
        android:bottom="400dp"
        android:left="-150dp"
        android:right="100dp"
        android:top="-150dp">
        <shape android:shape="oval">
            <gradient
                android:centerX="0.5"
                android:centerY="0.5"
                android:gradientRadius="400dp"
                android:startColor="#1AFF6B6B"
                android:endColor="#00FF6B6B"
                android:type="radial" />
        </shape>
    </item>

    <!-- Bulle de couleur en bas à droite -->
    <item
        android:bottom="-200dp"
        android:left="100dp"
        android:right="-200dp"
        android:top="300dp">
        <shape android:shape="oval">
            <gradient
                android:centerX="0.5"
                android:centerY="0.5"
                android:gradientRadius="500dp"
                android:startColor="#26FF6B6B"
                android:endColor="#00FF6B6B"
                android:type="radial" />
        </shape>
    </item>
</layer-list>