<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    <!-- Couleur quand le champ est focalisé (actif) -->
    <item android:color="@color/liquid_primary" android:state_focused="true" />
    <!-- Couleur quand le champ est en erreur (attribut Material) -->
    <item android:color="#D32F2F" app:state_error="true" />
    <!-- Couleur par défaut (inactif) -->
    <item android:color="@color/text_secondary" />
</selector>